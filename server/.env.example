MONGODB_URI=mongodb+srv://...
CHANNEL_ACCESS_TOKEN=
CHANNEL_SECRET=
OCR_API_KEY=

# LINE userId, groupId, or roomId. Separate multiple recipients with commas.
TARGET_PUSH_ID=

# Used by Google Apps Script as: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# Keep false in production unless the caller may choose a target recipient.
ALLOW_PUSH_TARGET_OVERRIDE=false

# Optional allowlist. When empty, trade-like messages from every joined group are recorded.
TRACKED_LINE_GROUP_IDS=

# LINE userId that receives follow-trade confirmation push messages.
ORDER_CONFIRM_LINE_USER_ID=

# Optional Python broker service endpoint. Leave empty for paper mode.
BROKER_ORDER_API_URL=
BROKER_ORDER_DRY_RUN=true
ORDER_INTENT_BUY_AMOUNT_TWD=100000
